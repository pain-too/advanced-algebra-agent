# ===================== Python 核心忽略 =====================
# 编译字节码
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.so
# 虚拟环境
.venv/
venv/
env/
ENV/
# 打包产物
*.egg-info/
dist/
build/
# 环境变量
.env
.env.*

# ===================== IDE/编辑器忽略 =====================
# PyCharm/IDEA
.idea/
*.iml
# VSCode
.vscode/
# 临时编辑文件
*.swp
*.swo
*~

# ===================== 项目专属忽略（匹配Agent内结构） =====================
# 向量库（Agent内的chroma_db）
Agent/chroma_db/
# 数据文件夹（Agent内的data，含PDF等原始资料）
Agent/data/
# 日志文件夹（Agent内的logs）
Agent/logs/
# MD5记录文件（Agent内的md5_record.txt）
Agent/md5_record.txt
# 系统隐藏文件（Agent内的.DS_Store）
Agent/.DS_Store
# 所有DS_Store文件
.DS_Store
.DS_Store?
._*
Thumbs.db

# ===================== 临时/冗余文件 =====================
*.tmp
*.temp
*.bak
*.log